library(FactoMineR)
library(agricolae)
library(ade4)
library(MASS)
library(ggplot2)
data(yacon)

yacon$hauteur = cut(yacon$height,
                    c(0,60,120,180,240,Inf)
)

# 1. PCA (principal component analysis) ####

quanti = yacon[,6:19]

# quanti = quanti[-225,] # ?

head(quanti)
cor(quanti)

res_pca = FactoMineR::PCA(quanti)

plot(res_pca$eig[,"cumulative percentage of variance"], type = "b")
abline(h = 80, col = "red")

plot(res_pca, axes = c(1, 2), choix = c("var"))
plot(res_pca, axes = c(3, 4), choix = c("var"))

plot(res_pca, axes = c(1, 2), choix = c("ind"))
plot(res_pca, axes = c(3, 4), choix = c("ind"))

# 2. LDA (linear discriminant analysis) ####
# => expliquer une quali par des quantis

## exemple 1 ####
table(yacon$locality)

res_lda = MASS::lda(locality ~ height +
            stalks +
            wfr +
            wff +
            wfk +
            roots +
            FOS +
            glucose +
            fructose +
            sucrose +
            brix +
            foliage  +
            dry +
            IH,
          data = yacon)


scores <- as.data.frame(predict(res_lda)$x)
scores$locality <- yacon$locality

vars <- yacon[, c("height","stalks","wfr","wff","wfk","roots",
                  "FOS","glucose","fructose","sucrose",
                  "brix","foliage","dry","IH")]

cor_df <- as.data.frame(cor(vars, scores[,1:2]))
cor_df$var <- rownames(cor_df)

theta <- seq(0, 2*pi, length.out = 100)
circle <- data.frame(x = cos(theta), y = sin(theta))

ggplot(cor_df, aes(x = LD1, y = LD2)) +
  geom_path(data = circle, aes(x = x, y = y), color = "black") +
  geom_segment(aes(x = 0, y = 0, xend = LD1, yend = LD2),
               arrow = arrow(length = unit(0.2,"cm")),
               color = "blue") +
  geom_text(aes(label = var), hjust = 1.1, vjust = 1.1) +
  geom_hline(yintercept = 0, linetype = "dashed") +
  geom_vline(xintercept = 0, linetype = "dashed") +
  coord_equal() +
  theme_minimal() +
  ggtitle("Cercle de corrélations (LDA)")

ggplot(scores, aes(x = LD1, y = LD2, color = locality)) +
  geom_point(size = 3, alpha = 0.8) +
  stat_ellipse() +
  theme_minimal() +
  ggtitle("Projection des individus (LDA)")

